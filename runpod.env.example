# ACE-Step RunPod Serverless Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control (it contains sensitive information)

# =============================================================================
# Required: Cloudflare R2 Storage Configuration
# =============================================================================
# Choose ONE of the following authentication methods:

# Method 1: Cloudflare REST API (Recommended - uses Bearer Token)
# Get your API token from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Account > Cloudflare R2 > Edit
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-bearer-token
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-public-domain.com

# Method 2: S3-Compatible API (Fallback - uses Access Key + Secret Key)
# Uncomment and fill these if you prefer S3-compatible authentication
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# R2_ACCESS_KEY=your-r2-access-key-id
# R2_SECRET_KEY=your-r2-secret-access-key

# =============================================================================
# Optional: ACE-Step Model Configuration
# =============================================================================
# Project root directory (default: current working directory)
# ACESTEP_PROJECT_ROOT=/path/to/project

# DiT model configuration
ACESTEP_CONFIG_PATH=acestep-v15-turbo
ACESTEP_DEVICE=auto

# Model optimization options
ACESTEP_USE_FLASH_ATTENTION=true
ACESTEP_COMPILE_MODEL=false
ACESTEP_OFFLOAD_TO_CPU=false
ACESTEP_OFFLOAD_DIT_TO_CPU=false

# LLM model configuration (optional, for CoT reasoning)
# Available models: acestep-5Hz-lm-0.6B (smallest), acestep-5Hz-lm-1.7B (recommended), acestep-5Hz-lm-4B (largest)
# For 16-24GB GPU, 1.7B is recommended. For smaller GPUs, use 0.6B.
ACESTEP_LM_MODEL_PATH=acestep-5Hz-lm-0.6B
ACESTEP_LM_BACKEND=vllm
ACESTEP_LM_OFFLOAD_TO_CPU=false
